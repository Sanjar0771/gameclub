# ============================================
# GameClub - Muhit o'zgaruvchilari (.env)
# ============================================

# === Umumiy ===
NODE_ENV=development
TZ=Asia/Tashkent

# === Database (PostgreSQL) ===
# Railway'da avtomatik beriladi. Local development uchun:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gameclub?schema=public

# === API server ===
API_PORT=3001
API_HOST=0.0.0.0
# WebApp domeni (CORS uchun)
WEBAPP_URL=https://your-app.vercel.app

# === Telegram Bot ===
# @BotFather'dan oling
BOT_TOKEN=1234567890:AAAA-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Bot username (faqat @ siz)
BOT_USERNAME=GameclubUzBot
# WebApp URL'ni botga ulash
BOT_WEBAPP_URL=https://your-app.vercel.app

# === Super-admin (birinchi marta seed paytida ishlatiladi) ===
# Telegram ID raqami (@userinfobot orqali biling)
SUPER_ADMIN_TELEGRAM_ID=123456789
SUPER_ADMIN_LOGIN=admin
SUPER_ADMIN_PASSWORD=changeme123

# === JWT ===
# Tasodifiy 32+ belgili string (openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-please-change
JWT_EXPIRES_IN=30d

# === QR HMAC ===
# QR kodlarni imzolash uchun maxfiy kalit
QR_SECRET=your-qr-secret-key-min-32-chars-please-change

# === Cloudinary (chek rasmlari uchun) ===
# https://cloudinary.com - bepul tarif kifoya
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# === Frontend (apps/webapp) ===
# Bu o'zgaruvchi Vercel'ga qo'shiladi
NEXT_PUBLIC_API_URL=https://your-railway-server.up.railway.app
